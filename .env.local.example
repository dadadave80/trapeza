# Circle Developer Console (https://console.circle.com)
# Format: TEST_API_KEY:<id>:<secret> for testnet; LIVE_API_KEY:... for mainnet (don't use).
CIRCLE_API_KEY=
# 32-byte hex. Generated via: bun run entity-secret:generate
CIRCLE_ENTITY_SECRET=
# Created once via: bun run create-wallet-set (writes the id to stdout)
CIRCLE_WALLET_SET_ID=
# Blockchain identifier used by Circle SDKs (do not change for the hackathon)
CIRCLE_ARC_BLOCKCHAIN=ARC-TESTNET
# Kit key for @circle-fin/app-kit Swap. Only needed if you swap the agent
# back to canonical Arc tokens (App Kit doesn't see the hackathon mocks).
# Leave blank when running against the mocks — the agent uses direct DCW
# mint/transfer calls instead. Create at https://console.circle.com → Kit Keys.
KIT_KEY=
# Filled in after `bun run deploy-anchor` succeeds via Circle Smart Contract Platform.
TRACE_ANCHOR_ADDRESS=
# Wallet (in CIRCLE_WALLET_SET_ID) used by deploy-anchor as the deployer. Needs
# enough Arc USDC for deploy gas. Create one via Circle Console or createWallets,
# fund from faucet.circle.com, paste id here.
CIRCLE_DEPLOY_WALLET_ID=

# Arc Testnet (canonical, per docs/circlefin-skills/use-arc.md)
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
# Hackathon mock token addresses (deployed via contracts/script/Deploy.s.sol).
# All four are 6 decimals and expose an open `mint(address,uint256)` so the
# in-app faucet works without a faucet ticket. Canonical Arc addresses are in
# docs/docs.arc.network/arc/references/contract-addresses.md if you ever need
# to switch back (and bump CIRBTC_DECIMALS to 8 in lib/constants.ts).
ARC_USDC_ADDRESS=0xf8075E9DE8E8D27F98D5C78Be26CEbceEd6f9A79
ARC_EURC_ADDRESS=0x72cfA7f9DfA38975f4ed4AcF86f67D6E490a52d8
ARC_CIRBTC_ADDRESS=0x8cad4951192853D14f8Cb813695146b5Ae00EA6d
# USYC mock — ERC4626 vault on top of MockUSDC, ~10% APY accrued per second.
ARC_USYC_ADDRESS=0x1Fc2873AABE4700dD2753e43B9566B5A7BbA902C
# MockSwap router — agent rebalances go through this and emit a clean
# `Swapped(from, tokenIn, tokenOut, amountIn, amountOut)` event per leg.
# Override only if you redeploy via contracts/script/DeployMockSwap.s.sol.
ARC_MOCKSWAP_ADDRESS=0xaf9879EDD99ce2F2Ea0CaFdF6Dd19da15B573a3f

# Groq (https://console.groq.com — free tier, no card required)
GROQ_API_KEY=
# Optional model overrides. Defaults are picked for free-tier eligibility
# + good reasoning quality. See /api/healthz for the live model list.
# LLM_FAST_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# LLM_HEAVY_MODEL=openai/gpt-oss-120b

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron protection. Long random string; Vercel passes as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
